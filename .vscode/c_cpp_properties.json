                "${env:HOME}/zephyr-sdk-1.0.1/gnu/arm-zephyr-eabi/include",
                "${env:HOME}/zephyr-sdk-1.0.1/gnu/arm-zephyr-eabi/arm-zephyr-eabi/include",
