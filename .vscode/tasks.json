{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build: Documentation",
			"group": {
				"kind": "build"
			},
			"problemMatcher": [],
			"type": "shell",
			"command": [
				"source ${workspaceFolder}/.venv/bin/activate",
				"&& cd doc",
				"&& pip install -r requirements.txt",
				"&& make clean",
				"&& make html"
			]
		},
		{
			"label": "Build: App",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc",
			"type": "shell",
			"command": [
				"source ${workspaceFolder}/.venv/bin/activate",
				"&& west build -b iida_devkit@4.2.1 app -- -DBOARD_ROOT=.."
			]
		}
	]
}