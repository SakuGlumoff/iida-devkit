{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build: App",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc",
			"type": "shell",
			"command": [
				"source ${workspaceFolder}/.venv/bin/activate",
				"&& west build -b iida_devkit@4.2.1 . -- -DBOARD_ROOT=."
			]
		}
	]
}