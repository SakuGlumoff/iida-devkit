	)
	(text_box "A 1S 3.7V nominal LiPo battery can be used to power the device.\n\nWhen powered by the battery, the device typically consumes between 10 mA (in sleep mode) and 700 mA (during data transmission).\n\nThe charging current is 450 mA, so connect a battery with a capacity of at least 450 mAh.\n\nWhen powered via USB-C, the battery can be charged."
		(exclude_from_sim no)
		(at 15.24 63.5 0)
		(size 58.42 71.12)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 2.54 2.54)
			)
			(justify left top)
		)
		(uuid "1c05e634-3508-41d1-b65a-143976157114")
	)
	(text_box "V_{DD} = 5V\nV_{BAT} = 3 V worst case\nI_{CHG} = 0.45 A\n\nMCP73833 datasheet:\n\nThermal resistance θ_{JA} is 41 °C/W.\nThermal shutdown T_{SD} is 150 °C.\nP = (5 V - 3 V) * I_{CHG} ~= 1 W\nMax temperature T_{CHG_MAX} = θ_{JA} * P = 41 °C\nT_{CHG_MAX} < T_{SD}"
		(exclude_from_sim no)
		(at 222.25 154.94 0)
		(size 50.8 24.13)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type color)
			(color 251 255 120 1)
		)
		(effects
