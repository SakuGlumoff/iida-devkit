			)
			(justify left top)
		)
		(border no)
		(stroke
			(width 0)
			(type solid)
		)
	)
	(gr_text_box "USB differential impedance calculation done with Sierra Circuits' Proto Express impedance app.\nThe differential pair is routed as coplanar uncoated microstrip differential pair with the following parameters:\n- Signal layer: TOP\n- Reference layer: IN1 (GND)\n- Dielectric height: 0.23 mm\n- Dielectric constant: 4.3\n- Trace width: 0.345 mm\n- ΔW (width difference between trace bottom and trace top): 0 mm\n- Trace thickness: 0.035 mm\n- Trace separation: 0.15 mm\n- Conductor spacing (between trace and coplanar ground): 0.15 mm\n- Conductor width: 2.54 mm\n- Target diff. impedance (Zd): 90 Ω"
		(start 13.425725 161.836182)
		(end 51.220925 197.421583)
		(margins 0 0 0 0)
