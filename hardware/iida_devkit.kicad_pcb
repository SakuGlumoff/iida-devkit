	(gr_text_box "Antenna feedline impedance calculation done with Saturn PCB Toolkit V8.39.\nThe feedline is routed as Coplanar Waveguide with the following parameters:\n- Dielectric constant: 4.3\n- Base copper weight: 0.018 mm\n- Plating thickness: 0.018 mm\n- Impedance (Zo): 50.0038 Ω\n- Dielectric height: 0.36 mm\n- Conductor width: 0.69 mm\n- Conductor gap: 0.5 mm"
		(start 51.525725 161.836182)
		(end 89.320925 197.421583)
		(margins 0 0 0 0)
		(layer "Cmts.User")
