	)
	(text_box "Buck-Boost regulator with soft start\n\nThe regulator is capable of sourcing\n700 mA @ 3 V_{IN} and 900 mA @ 5 V_{IN}.\n\nThe MCU drains about 100 mA in a worst case scenario.\nThe modem drains about 500 mA in a worst case scenario.\n\n700 mA ≥ (100 mA + 500 mA)"
		(exclude_from_sim no)
		(at 201.93 34.29 0)
		(size 58.42 22.86)
		(stroke
			(width 0)
			(type default)
