		(uuid "27350b12-6e31-43a8-99ca-abfc7a2cffc6")
	)
	(text "Place the 1 cm x 1 cm ground test point on the edge of\nthe PCB so that the oscilloscope ground can\nbe connected to it with an alligator clip."
		(exclude_from_sim no)
		(at 317.5 243.84 0)
		(effects
