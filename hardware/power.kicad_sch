		)
		(uuid "9914436d-6519-463e-afc7-dcabfa0874db")
	)
	(text "For current measurements,\npopulate the header and\nremove the 0 Ω jumper."
		(exclude_from_sim no)
		(at 317.5 120.65 0)
		(effects
