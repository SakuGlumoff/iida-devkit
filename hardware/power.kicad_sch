	(text_box "R_{DS_ON} @ Ta ~= 25 mΩ\n(25 mΩ * 2) + 50 mΩ = 0.1 Ω"
		(exclude_from_sim no)
		(at 68.58 101.6 0)
		(size 34.29 6.35)
		(stroke
			(width 0)
			(type default)
		)
		(fill
			(type color)
			(color 251 255 120 1)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "03a2fcbf-595a-4b0e-8471-b24003cbf6fc")
	)
	(text_box "Battery protection\n\nOvercharge detection: 4.28 V\nOverdischarge detection: 2.8 V\nDischarge overcurrent detection: 0.05 V\nCharge overcurrent detection: -0.05 V\nShort-circuit detection: 0.3 V\n\nMaximum desired discharge current is 2 A.\nTotal resistance across FETs should be\n0.05 V / 2 A = 0.1 Ω.\n\nMaximum desired charge current is 500 mA.\n0.1 Ω * 0.5 A = 0.05 V trigger level."
		(exclude_from_sim no)
		(at 73.66 21.59 0)
		(size 33.02 41.91)
		(stroke
			(width 0)
			(type default)
		)
		(fill
			(type color)
			(color 251 255 120 1)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "3522478c-4893-431c-8ff6-136c49a1b22e")
	)
	(text_box "Battery charging\nEnabled only when USB connection is ON.\n\nV_{IN} = 5 V\nV_{OUT} = 3 V worst case\nI_{CHG} = 0.5 A\n\nBQ21040 datasheet:\n\nThermal resistance R_{θJA} is 130.8 °C/W.\nThermal shutdown T_{SD} is 155 °C.\nP = (V_{IN} - V_{OUT}) * I_{CHG} = 1 W\nMax temperature T_{CHG_MAX} = R_{θJA} * P = 130.8 °C\nT_{SD} > T_{CHG_MAX}\n\n9.2.2.1.1 Program the ISET:\nK_{ISET} = 540 AΩ\nR_{ISET} = 540 AΩ / I_{CHG} = 1080 Ω"
		(exclude_from_sim no)
		(at 115.57 21.59 0)
		(size 43.18 41.91)
		(stroke
			(width 0)
			(type default)
		)
		(fill
			(type color)
			(color 251 255 120 1)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "743186ee-8e52-488e-953c-466fe1042f08")
	)
	(text_box "CC1 & CC2 tied to ground with 5.1 kΩ resistors -> 15 W can be drawn.\nP = U * I -> 15 W = 5 V * 3 A"
		(exclude_from_sim no)
		(at 45.72 157.48 0)
		(size 49.53 8.89)
		(stroke
			(width 0)
			(type default)
		)
		(fill
