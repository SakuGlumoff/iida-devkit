	)
	(text "Battery protection\n\nOvercharge detection: 4.28 V\nOverdischarge detection: 2.8 V\nDischarge overcurrent detection: 0.05 V\nCharge overcurrent detection: -0.05 V\nShort-circuit detection: 0.3 V\n\nMaximum desired discharge current is 2 A.\nTotal resistance across FETs should be\n0.05 V / 2 A = 0.1 Ω.\n\nMaximum desired charge current is 500 mA.\n0.1 Ω * 0.5 A = 0.05 V trigger level."
		(exclude_from_sim no)
		(at 87.884 41.148 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c2d89405-9ce5-4789-88d6-55812ecfa79c")
	)
	(text "Battery charging\nEnabled only when USB connection is ON.\n\nV_{IN} = 5 V\nV_{OUT} = 3 V worst case\nI_{CHG} = 0.5 A\n\nBQ21040 datasheet:\n\nThermal resistance R_{θJA} is 130.8 °C/W.\nThermal shutdown T_{SD} is 155 °C.\nP = (V_{IN} - V_{OUT}) * I_{CHG} = 1 W\nMax temperature T_{CHG_MAX} = R_{θJA} * P = 130.8 °C\nT_{SD} > T_{CHG_MAX}\n\n9.2.2.1.1 Program the ISET:\nK_{ISET} = 540 AΩ\nR_{ISET} = 540 AΩ / I_{CHG} = 1080 Ω"
		(exclude_from_sim no)
		(at 134.366 37.084 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d0d5b65a-6749-41b7-9f4b-d03b6a833f85")
	)
	(text "Place a jumper/ammeter\nto enable/measure\nthe power line."
		(exclude_from_sim no)
		(at 236.982 112.014 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d110148d-42ce-47f2-b4b5-ac5baa2e2f0a")
	)
	(text "Header for measuring the 3.3V power line."
		(exclude_from_sim no)
		(at 236.982 122.174 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "dab9aeaa-7c59-458f-9996-43159f526cd8")
	)
	(text "The regulator is capable of sourcing\n700 mA @ 3 V_{IN} and 900 mA @ 5 V_{IN}.\n\nThe MCU drains about 100 mA in a worst case scenario.\nThe modem drains about 500 mA in a worst case scenario.\n\n700 mA ≥ (100 mA + 500 mA)"
		(exclude_from_sim no)
		(at 225.552 92.202 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "f4fbc571-4a5e-40cb-8822-91939c5b1af3")
	)
