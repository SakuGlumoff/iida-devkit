	)
	(text "Power path management\n\nIf V_BAT > V_5V0, V_{OUT} = V_BAT\nIf V_5V0 > V_BAT, V_{OUT} = V_5V0"
		(exclude_from_sim no)
		(at 50.8 133.35 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d7c068cc-910f-431e-8046-261b824eb479")
	)
	(text_box "Notes"
		(exclude_from_sim no)
		(at 12.7 251.46 0)
		(size 285.75 33.02)
		(margins 0.9525 2 0.9525 0.9525)
		(stroke
			(width 0)
