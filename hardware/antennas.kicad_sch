			(justify left top)
		)
		(uuid "375f1241-db81-43b7-9c52-e0e846818a84")
	)
	(text_box "Since the SMA jack is a human interface, provide ESD protection for it.\n\nEnsure that the TVS protection does not negatively affect the matching network too much."
		(exclude_from_sim no)
		(at 332.74 63.5 0)
		(size 71.12 31.75)
