	(text_box "- Follow the antenna layout guidelines according to \"SARA-R5 series - System integration manual\" (UBX-19041356 - R20)\n  chapter \"2.4.1 General guidelines for antenna interfaces\"."
		(exclude_from_sim no)
		(at 13.97 260.35 0)
		(size 281.94 22.86)
