			)
			(justify left top)
		)
		(uuid "acbbba09-9eea-497f-884b-25bdb9c862d4")
	)
	(text_box "The device incorporates an integrated PCB antenna as well as an SMA jack.\n\nSelection between the two antennas is made using a 0402 0 Ω jumper to minimize impedance mismatch in the antenna rail."
		(exclude_from_sim no)
		(at 13.97 50.8 0)
